# =============================================================================
# livros-converter — variáveis de ambiente
# Copie este arquivo para `.env` e preencha o que for usar.
# =============================================================================

# --- Gemini API (usado para páginas com OCR ruim / visão / fallback texto) ---
# Pegue em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelos (deixe os defaults se não souber)
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_VISION_MODEL=gemini-2.5-pro

# --- Claude CLI (provider primário para texto) ---
# O CLI deve estar instalado e logado. Não precisa de API key aqui.
CLAUDE_CLI_BIN=claude
CLAUDE_CLI_MODEL=

# --- Ollama (fallback local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:13b

# --- OCR ---
# Modos disponíveis:
#   paddle              PaddleOCR; fallback Tesseract se conf baixa
#   glm                 GLM-OCR; fallback Paddle se vazio
#   paddle-then-glm     Paddle → escala para GLM se conf < min
#   glm-then-paddle     GLM → fallback Paddle
#   compare             roda Paddle + GLM e escolhe vencedor por métrica (gera relatório)
OCR_MODE=compare

# PaddleOCR
PADDLE_OCR_LANG=pt

# Tesseract (fallback). Aponte para o binário no Windows.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_LANG=por

# GLM-OCR (zai-org/GLM-OCR). pip install glmocr
# (selfhosted: pip install "glmocr[selfhosted]" — exige GPU)
# Se quiser incluir tesseract no modo compare:
COMPARE_INCLUDE_TESSERACT=0

# Limite de confiança abaixo do qual escala para LLM-vision (0..1)
OCR_MIN_CONFIDENCE=0.80

# --- Pipeline ---
# Tamanho do lote de páginas enviado ao LLM por vez (3 a 6 recomendado)
BATCH_SIZE=5
# Quantas páginas de overlap entre lotes consecutivos
BATCH_OVERLAP=1

# Roteamento padrão: ordem de tentativa (separado por vírgula)
# Opções: claude-cli, gemini, ollama
LLM_ORDER_TEXT=claude-cli,gemini,ollama
LLM_ORDER_VISION=gemini,ollama

# Caminho para o python (se não estiver no PATH)
PYTHON_BIN=python
